# ==========================================================
# TGO 单机部署配置
# ==========================================================
# 复制此文件为 .env 并修改必要参数
# cp .env.standalone.example .env
# ==========================================================

# ==========================================================
# 必填配置 - 请根据你的实际情况修改
# ==========================================================

# 服务器公网IP或域名
SERVER_HOST=your-server-ip

# 数据库配置
POSTGRES_DB=tgo
POSTGRES_USER=tgo
POSTGRES_PASSWORD=请修改为强密码
POSTGRES_PORT=5432

# Redis配置
REDIS_PORT=6379

# 前端API地址 (宝塔Nginx反代后的地址)
# 例如: https://your-domain.com/api
VITE_API_BASE_URL=/api

# WebSocket地址 (HTTPS下必须用wss)
# 例如: wss://your-domain.com/ws
WUKONGIM_WSS_ADDR=wss://your-domain.com/ws

# ==========================================================
# 安全配置 - 生产环境必须修改
# ==========================================================

# JWT密钥 (运行: openssl rand -hex 32 生成)
SECRET_KEY=请运行_openssl_rand_hex_32_生成并替换

# Token过期时间 (分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ==========================================================
# 存储配置
# ==========================================================
STORAGE_TYPE=local

# ==========================================================
# 日志级别
# ==========================================================
LOG_LEVEL=DEBUG

# ==========================================================
# 环境标识
# ==========================================================
ENVIRONMENT=PRODUCTION

# ==========================================================
# 可选配置
# ==========================================================

# Store服务 (可选)
STORE_SERVICE_URL=https://store.tgo.ai
STORE_WEB_URL=https://store.tgo.ai

# Widget配置
VITE_WIDGET_PREVIEW_URL=/widget/
VITE_WIDGET_SCRIPT_BASE=/widget/tgo-widget-sdk.js
VITE_WIDGET_DEMO_URL=/widget/demo.html
VITE_DEBUG_MODE=false
